# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="ZKR E-Commerce"
NODE_ENV=development

# NextAuth (v5)
AUTH_SECRET="change-me-to-random-32-char-string"
AUTH_URL="http://localhost:3000/api/auth"

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zkr_ecommerce?schema=public"

# Redis (via Docker)
REDIS_URL="redis://localhost:6379"

# OAuth (optional - leave blank to skip)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="ZKR Store <noreply@zkrstore.com>"

# Stripe (optional for testing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Upload (optional)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
AUTH_SECRET=my-super-secret-key-change-this
