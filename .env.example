# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="ZKR E-Commerce"
NODE_ENV=development

# Authentication (NextAuth v4)
# NextAuth v4 reads NEXTAUTH_URL by default. AUTH_SECRET is wired explicitly
# in src/lib/auth.ts (with NEXTAUTH_SECRET supported as a fallback name).
AUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Database (PostgreSQL — e.g. Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zkr_ecommerce?schema=public"

# Redis (optional — used for rate limiting/caching if configured)
REDIS_URL="redis://localhost:6379"

# OAuth (optional — leave blank to disable Google/GitHub sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (Resend) — used for verification, password reset, order confirmation,
# and the contact form
RESEND_API_KEY=
EMAIL_FROM="ZKR E-Commerce <noreply@zkrstore.com>"
# Where contact form submissions are delivered (defaults to a hardcoded
# address in src/lib/email.ts if unset)
CONTACT_EMAIL_TO=

# Stripe — required for checkout to create real payment sessions
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# File uploads (optional)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
